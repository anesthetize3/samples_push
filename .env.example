# Required (production sink)
FILESCAN_API_KEY=

# Optional — used when the run targets staging.filescan.io
# (selected via --staging, --filescan-url=https://staging.filescan.io, or
#  FILESCAN_BASE_URL=https://staging.filescan.io). Falls back to
# FILESCAN_API_KEY if unset, but staging usually issues its own key.
FILESCAN_STAGING_API_KEY=

# Optional: override filescan target. Default: https://www.filescan.io
# Examples:
#   FILESCAN_BASE_URL=https://staging.filescan.io
#   FILESCAN_BASE_URL=https://www.filescan.io
FILESCAN_BASE_URL=

# Optional — sources whose keys are missing will be auto-disabled.
# One abuse.ch Auth-Key works for both MalwareBazaar and URLhaus.
# Get a free key at https://auth.abuse.ch/
ABUSECH_API_KEY=
MALSHARE_API_KEY=
VX_API_KEY=
INQUEST_API_KEY=
VIRUSSHARE_API_KEY=
# Hybrid Analysis: free signup, but the default ("restricted") key cannot
# download samples. Request upgrade to "default" auth level on your profile.
HYBRID_API_KEY=

# Optional: pin a specific VirusShare hash list (e.g. 499). If unset, the
# source auto-discovers the latest published list.
VIRUSSHARE_HASHLIST_INDEX=

# Optional: Private git repo to sync state.db between machines.
# Prevents duplicate uploads when running on multiple devices.
# Create a private repo (e.g. gh repo create samples-push-state --private)
# STATE_REPO_URL=git@github.com:user/samples-push-state.git
STATE_REPO_URL=
